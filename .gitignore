# .gitignore

# ── Next.js ───────────────────────────────────────────────────────────────────
.next/
out/
build/

# ── Node ─────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Environment variables — NEVER commit these ────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Prisma ────────────────────────────────────────────────────────────────────
# Don't ignore schema.prisma or migrations — those should be committed
# prisma/migrations/  <-- keep this committed

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
*.swp
*.swo
.vscode/settings.json
.idea/

# ── Vercel ────────────────────────────────────────────────────────────────────
.vercel

# ── Misc ──────────────────────────────────────────────────────────────────────
*.log
*.pid
coverage/
.nyc_output/
dist/
