# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git — it's already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Get this from Railway, Supabase, or Neon (all have free tiers)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/portfolio?schema=public"

# ── Email (Nodemailer via Gmail) ──────────────────────────────────────────────
# For Gmail: enable 2FA, then create an App Password at:
# https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your.gmail@gmail.com"
SMTP_PASS="your-16-char-app-password"
SMTP_FROM='"Swagata Portfolio" <your.gmail@gmail.com>'

# Your personal email where contact form notifications will be sent
PORTFOLIO_EMAIL="contact@swagata.dev"

# ── Admin secret (for /api/contact GET endpoint) ──────────────────────────────
# Generate with: openssl rand -base64 32
ADMIN_SECRET="replace-with-a-long-random-string"

# ── Next.js ───────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NODE_ENV="development"
